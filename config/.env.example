# =============================================================================
# CONFIGURACAO DO FLUXO DE AGENTES v3.0
# =============================================================================

# Copie este arquivo para .env e preencha com suas chaves de API

# -----------------------------------------------------------------------------
# NVIDIA AI (RECOMENDADO - GRATIS)
# Obtenga em: https://org.ngc.nvidia.com/setup/personal-keys
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=sua_chave_nvidia_aqui

# -----------------------------------------------------------------------------
# GOOGLE GEMINI (OPCIONAL - GRATIS)
# Obtenga em: https://aistudio.google.com/app/u/1/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# OPENAI GPT-4 (OPCIONAL - PAGAMENTO POR USO)
# Obtenga em: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# ANTHROPIC CLAUDE (OPCIONAL - PAGAMENTO POR USO)
# Obtenga em: https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# GMAIL - ENVIO DE EMAILS (PROSPECTOR)
# 1. Acesse myaccount.google.com/security
# 2. Ative Verificacao em 2 Etapas
# 3. Va em Senhas de App (myaccount.google.com/apppasswords)
# 4. Gere uma senha de app e configure abaixo
# -----------------------------------------------------------------------------
GMAIL_EMAIL=seuemail@gmail.com
GMAIL_APP_PASSWORD=sua_senha_de_app_aqui
GMAIL_FROM_NAME=Seu Nome

# -----------------------------------------------------------------------------
# AUTENTICACAO
# -----------------------------------------------------------------------------
ADMIN_PASSWORD=admin123
USER_PASSWORD=user123

# =============================================================================
# NOTAS
# =============================================================================
# 
# NVIDIA AI e GRATIS e recomendado para comecar
#   - Modelos: Nemotron, Llama, Mistral, Qwen, DeepSeek, Kimi
#   - Limite generoso para uso pessoal
#
# GEMINI tambem e gratis com GOOGLE_API_KEY
#
# GPT-4 e Claude requerem pagamento por uso
#
# =============================================================================
